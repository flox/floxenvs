{
  "name": "mariadb",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu26.04",
  "workspaceFolder": "/workspaces/floxenvs/mariadb",
  "runArgs": [
    "--security-opt",
    "seccomp=unconfined"
  ],
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  "mounts": [
    "source=floxenvs-nix-store,target=/nix,type=volume"
  ],
  "forwardPorts": [],
  "portsAttributes": {},
  "containerEnv": {
    "FLOX_DISABLE_METRICS": "true",
    "NIX_REMOTE": "auto"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "flox.flox"
      ]
    }
  },
  "postCreateCommand": "bash /workspaces/floxenvs/.devcontainer/scripts/post-create.sh mariadb",
  "postStartCommand": "bash /workspaces/floxenvs/.devcontainer/scripts/post-start.sh mariadb",
  "remoteUser": "root"
}
