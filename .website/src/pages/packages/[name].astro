---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import KindBadge from "../../components/KindBadge.astro";
import ScoreSlot from "../../components/ScoreSlot.astro";
import InstallTabs from "../../components/InstallTabs.astro";
import SidebarEntry from "../../components/SidebarEntry.astro";
import Markdown from "../../components/Markdown.astro";

export async function getStaticPaths() {
  const pkgs = await getCollection("packages");
  return pkgs.map((p) => ({ params: { name: p.data.name }, props: { pkg: p } }));
}

const { pkg } = Astro.props as { pkg: { data: any } };
const base = import.meta.env.BASE_URL;
const envs = await getCollection("envs");

const useWithEnvs = envs.filter((e) => {
  const reverseRef = pkg.data.combines_well_with.includes(`env:${e.data.name}`);
  const forwardRef = e.data.combines_well_with.includes(`pkg:${pkg.data.name}`);
  const bundled = (e.data.manifest_install ?? [])
    .some((mi: { name: string }) => mi.name === pkg.data.name);
  return reverseRef || forwardRef || bundled;
});

const otherPkgs = (await getCollection("packages")).filter((p) =>
  p.data.name !== pkg.data.name &&
  (pkg.data.combines_well_with.includes(`pkg:${p.data.name}`) ||
   p.data.combines_well_with.includes(`pkg:${pkg.data.name}`)),
);

const tabs = pkg.data.install?.pkg
  ? [{ label: "Manifest", code: pkg.data.install.pkg }]
  : [];

const ogImage = pkg.data.featured
  ? `${base}og/pkg/${pkg.data.name}.png`
  : undefined;
---
<Layout
  title={`${pkg.data.title} · flox/envs`}
  description={pkg.data.tagline}
  ogImage={ogImage}
>
  <nav class="text-sm text-slate-500 mb-4">
    <a href={`${base}packages/`} class="underline">Packages</a>
    {pkg.data.subkind === "plugin" && (
      <> / <a href={`${base}packages/plugins/`} class="underline">Plugins</a></>
    )}
    {pkg.data.subkind === "skill" && (
      <> / <a href={`${base}packages/skills/`} class="underline">Skills</a></>
    )}
    {" "}/ {pkg.data.name}
  </nav>

  <div class="flex items-center gap-3 mb-2">
    <KindBadge kind={pkg.data.subkind ?? "pkg"} />
    <span class="text-xs font-mono text-slate-500">{pkg.data.status}</span>
  </div>
  <h1 class="text-3xl font-bold">{pkg.data.title}</h1>
  <p class="mt-2 text-slate-600 dark:text-slate-300">{pkg.data.tagline}</p>

  {pkg.data.summary.length > 0 && (
    <ul class="mt-4 list-disc list-inside text-sm">
      {pkg.data.summary.map((s: string) => <li>{s}</li>)}
    </ul>
  )}

  <div class="grid lg:grid-cols-[1fr_280px] gap-10 mt-10">
    <div>
      <ScoreSlot
        kind="pkg"
        name={pkg.data.name}
        metrics={pkg.data.metrics}
      />

      {tabs.length > 0 && (
        <section class="mt-8">
          <h2 class="text-xl font-semibold mb-3">Install</h2>
          <InstallTabs tabs={tabs} />
        </section>
      )}

      {useWithEnvs.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold">Use with these environments</h2>
          <div class="mt-4 grid sm:grid-cols-2 gap-3">
            {useWithEnvs.map((e) => (
              <a
                href={`${base}envs/${e.data.name}/`}
                class="block p-3 rounded-lg border border-slate-200 dark:border-slate-800 hover:border-slate-400"
              >
                <div class="flex items-center gap-2">
                  <KindBadge kind="env" />
                  <span class="font-semibold">{e.data.title}</span>
                </div>
                <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                  {e.data.tagline}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}

      {otherPkgs.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold">Combines with these packages</h2>
          <div class="mt-4 grid sm:grid-cols-2 gap-3">
            {otherPkgs.map((p) => (
              <a
                href={`${base}packages/${p.data.name}/`}
                class="block p-3 rounded-lg border border-slate-200 dark:border-slate-800 hover:border-slate-400"
              >
                <div class="flex items-center gap-2">
                  <KindBadge kind={p.data.subkind ?? "pkg"} />
                  <span class="font-semibold">{p.data.title}</span>
                </div>
                <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                  {p.data.tagline}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}

      {pkg.data.readme && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold">Documentation</h2>
          <Markdown source={pkg.data.readme} className="mt-3" />
        </section>
      )}
    </div>

    <aside class="space-y-1">
      <SidebarEntry label="Status">{pkg.data.status}</SidebarEntry>
      <SidebarEntry label="Publisher">{pkg.data.publisher}</SidebarEntry>
      {pkg.data.license && <SidebarEntry label="License">{pkg.data.license}</SidebarEntry>}
      {pkg.data.upstream && (
        <SidebarEntry label="Upstream">
          <a href={pkg.data.upstream.url} class="underline">
            {pkg.data.upstream.name}
          </a>
        </SidebarEntry>
      )}
      {pkg.data.maintainer && (
        <SidebarEntry label="Maintainer">{pkg.data.maintainer}</SidebarEntry>
      )}
      {pkg.data.plugin_for && (
        <SidebarEntry label="Plugin for">
          <a href={`${base}packages/${pkg.data.plugin_for}/`} class="underline">
            {pkg.data.plugin_for}
          </a>
        </SidebarEntry>
      )}
      {pkg.data.skill_for && (
        <SidebarEntry label="Skill for">
          <a href={`${base}packages/${pkg.data.skill_for}/`} class="underline">
            {pkg.data.skill_for}
          </a>
        </SidebarEntry>
      )}
      {useWithEnvs.length > 0 && (
        <SidebarEntry label="Bundled by envs">
          <span class="inline-flex flex-wrap gap-x-1.5 gap-y-1">
            {useWithEnvs.map((e) => (
              <a href={`${base}envs/${e.data.name}/`} class="underline decoration-slate-300 dark:decoration-slate-700 hover:decoration-slate-700 dark:hover:decoration-slate-300">{e.data.name}</a>
            ))}
          </span>
        </SidebarEntry>
      )}
      {pkg.data.links?.floxhub && (
        <SidebarEntry label="FloxHub">
          <a href={pkg.data.links.floxhub} class="underline">link</a>
        </SidebarEntry>
      )}
    </aside>
  </div>
</Layout>
