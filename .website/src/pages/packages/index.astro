---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ItemCard from "../../components/ItemCard.astro";

const base = import.meta.env.BASE_URL;
const pkgs = (await getCollection("packages")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
---
<Layout title="Packages · flox/envs" description="All Flox packages.">
  <h1 class="text-2xl font-bold">Packages</h1>
  <p class="mt-1 text-sm text-slate-500">
    {pkgs.length} packages
  </p>
  <div class="mt-4 flex gap-2 text-sm">
    <a href={`${base}packages/plugins/`} class="underline">Plugins</a>
    <a href={`${base}packages/skills/`} class="underline">Skills</a>
  </div>
  <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {pkgs.map((p) => (
      <ItemCard
        kind="pkg"
        subkind={p.data.subkind}
        name={p.data.name}
        title={p.data.title}
        tagline={p.data.tagline}
        href={`${base}packages/${p.data.name}/`}
        ai_role={p.data.ai_role}
        category={p.data.category}
      />
    ))}
  </div>
</Layout>
