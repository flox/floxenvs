---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import ItemCard from "../../../components/ItemCard.astro";

const base = import.meta.env.BASE_URL;
const pkgs = (await getCollection("packages"))
  .filter((p) => p.data.subkind === "skill" || p.data.subkind === "plugin")
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---
<Layout
  title="Claude Code skills on Flox — packaged, pinned, one-line install"
  description="Every Claude Code skill packaged for Flox — domain-specific capability bundles like writing, coding, and shell utilities. Each one Nix-pinned and reproducible."
>
  <h1 class="text-2xl font-bold">Skills</h1>
  <p class="mt-1 text-sm text-slate-500">{pkgs.length} skills</p>
  <p class="mt-4 text-base leading-relaxed text-slate-700 dark:text-slate-300 max-w-3xl">
    Skills are capability bundles for Claude Code — packaged prompts,
    scripts, and configurations that give an agent specific expertise.
    The packages on this page wrap each one as a Flox-installable,
    Nix-pinned bundle so a team gets identical agent behavior across every
    developer's machine. Add a skill via
    <code class="font-mono text-sm">flox/skills-&lt;name&gt;</code> in any
    manifest's <code class="font-mono text-sm">[install]</code> block.
  </p>
  <p class="mt-3 text-base leading-relaxed text-slate-700 dark:text-slate-300 max-w-3xl">
    The catalog spans two shapes, marked by the badge on each card: a
    single tightly-scoped <span class="font-medium">skill</span> (teach
    the agent your release-note format, your incident runbook, your house
    style) and a full <span class="font-medium">plugin</span> bundle that
    also extends the agent runtime (MCP servers, command palettes, hooks).
    Both package the same way — version-locked, manifest-included,
    reproducible. Bring up a fresh laptop, run
    <code class="font-mono text-xs">flox activate</code>, and the same
    agent with the same skills is ready to go.
  </p>
  <p class="mt-3 text-base leading-relaxed text-slate-700 dark:text-slate-300 max-w-3xl">
    Pair any of these with <a href={`${base}packages/flox-ai/`} class="underline">flox-ai</a>,
    which discovers installed skill and plugin bundles and materializes
    them into the agent's config tree on activation, then launch the agent
    with <code class="font-mono text-xs">flox-ai launch claude</code>. No
    copy-pasting prompts between machines, no drift between a developer's
    local skills and the CI runner's.
  </p>
  <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {pkgs.map((p) => (
      <ItemCard
        kind="pkg"
        subkind={p.data.subkind}
        name={p.data.name}
        title={p.data.title}
        tagline={p.data.tagline}
        href={`${base}packages/${p.data.name}/`}
        ai_role={p.data.ai_role}
      />
    ))}
  </div>
</Layout>
