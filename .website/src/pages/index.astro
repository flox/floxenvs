---
// .website/src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import AiEnvBuilder from "../components/builder/AiEnvBuilder.tsx";
import { readFileSync } from "node:fs";
import { join } from "node:path";

// Bundle the current data.json as an offline-first snapshot; the island
// refreshes from the live URL on load.
let snapshot: unknown = { items: [] };
try {
  snapshot = JSON.parse(
    readFileSync(join(import.meta.dirname, "..", "..", "public", "data.json"), "utf8"),
  );
} catch {
  /* data.json not built yet; island fetches live */
}
---

<Layout
  title="Build an AI environment you can rebuild. Flox"
  description="Pick your agent, skills, and audit tools. Walk away with a pinned flox snippet you can rebuild from scratch."
>
  <AiEnvBuilder client:load snapshot={snapshot} />
</Layout>
