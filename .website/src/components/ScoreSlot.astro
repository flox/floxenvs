---
import ScorePanel from "./ScorePanel.astro";
import { defaultMetrics, MetricsSchema } from "../lib/metricsSchema";
import type { Metrics } from "../lib/metricsSchema";

interface Props {
  kind: "env" | "pkg";
  name: string;
  // Pages already have the metrics on the entry — they
  // can pass it in directly to avoid an extra parse.
  metrics?: Metrics;
}
const { kind, name, metrics } = Astro.props as Props;
const m = metrics
  ? MetricsSchema.parse(metrics)
  : defaultMetrics({ kind, name });
---
<ScorePanel metrics={m} />
