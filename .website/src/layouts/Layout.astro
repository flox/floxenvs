---
import "../styles/global.css";
const {
  title,
  description,
  ogImage,
} = Astro.props as {
  title: string;
  description?: string;
  ogImage?: string;
};
const base = import.meta.env.BASE_URL;
const site = Astro.site?.toString() ?? "";
const defaultOg = `${site}${base}og/default.png`;
const og = ogImage ?? defaultOg;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={`${base}favicon.svg`} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={og} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={og} />
  </head>
  <body class="font-sans antialiased min-h-dvh bg-white text-slate-900 dark:bg-slate-950 dark:text-slate-100">
    <header class="border-b border-slate-200 dark:border-slate-800">
      <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center gap-6">
        <a href={base} class="font-bold tracking-tight">flox / envs</a>
        <a href={`${base}envs/`} class="text-sm text-slate-600 dark:text-slate-300">Envs</a>
        <a href={`${base}packages/`} class="text-sm text-slate-600 dark:text-slate-300">Packages</a>
        <a href={`${base}search/`} class="text-sm text-slate-600 dark:text-slate-300 ml-auto">Search</a>
        <a href="https://github.com/flox/floxenvs" class="text-sm text-slate-600 dark:text-slate-300">GitHub</a>
      </nav>
    </header>
    <main class="max-w-6xl mx-auto px-6 py-10">
      <slot />
    </main>
    <footer class="border-t border-slate-200 dark:border-slate-800 mt-20">
      <div class="max-w-6xl mx-auto px-6 py-6 text-sm text-slate-500">
        Built from <a class="underline" href="https://github.com/flox/floxenvs">flox/floxenvs</a>.
      </div>
    </footer>
  </body>
</html>
