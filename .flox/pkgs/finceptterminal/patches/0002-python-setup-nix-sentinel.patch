@@ -208,6 +208,16 @@
 SetupStatus PythonSetupManager::check_status() const {
     SetupStatus status;
     status.install_dir = install_dir();
+
+    // Flox/Nix short-circuit: when the install dir contains a
+    // sentinel from the Nix build, treat UV + Python as already
+    // installed. The venv-readiness check below still runs against
+    // the marker hashes and decides per-venv ready state.
+    if (QFileInfo::exists(status.install_dir + "/.fincept-nix-managed")) {
+        status.uv_installed = true;
+        status.python_installed = true;
+        status.python_version = QStringLiteral("nix-managed");
+    }

     LOG_INFO("PythonSetup", "=== check_status BEGIN === install_dir: " + status.install_dir);

