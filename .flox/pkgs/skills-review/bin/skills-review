#!/usr/bin/env bash
set -euo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
# Source helper libs from $SKILLS_REVIEW_LIB when packaged (Task 15), else
# from the in-tree lib/ next to this script.
LIB="${SKILLS_REVIEW_LIB:-$HERE/lib}"
# shellcheck source=/dev/null
. "$LIB/score.sh"
# shellcheck source=/dev/null
. "$LIB/adapters.sh"
# shellcheck source=/dev/null
. "$LIB/detect.sh"

DRY="${SKILLS_REVIEW_DRY_RUN:-}"
CMD="${1:?usage: skills-review <lint|review|audit> [opts] <path>}"; shift
KIND=""; JSON=""; WITH_BEHAVIORAL=""; THRESHOLD=""; PATH_ARG=""
while [ $# -gt 0 ]; do
  case "$1" in
    --kind) KIND="$2"; shift 2 ;;
    --json) JSON=1; shift ;;
    --with-behavioral) WITH_BEHAVIORAL=1; shift ;;
    --threshold) THRESHOLD="$2"; shift 2 ;;
    *) PATH_ARG="$1"; shift ;;
  esac
done
[ -n "$PATH_ARG" ] || { echo "no path given" >&2; exit 2; }
[ -n "$KIND" ] || KIND="$(detect_kind "$PATH_ARG")"

tmpd="$(mktemp -d)"; trap 'rm -rf "$tmpd"' EXIT

# --- claudelint / cclint staging -------------------------------------------
# claudelint and cclint operate on a Claude project layout (.claude/skills
# and .claude/agents), and cclint refuses paths outside the cwd tree. Stage
# the artifact into a temp project under $tmpd and echo that project root.
stage_project() {
  local proj="$tmpd/proj"
  rm -rf "$proj"; mkdir -p "$proj"
  if [ "$KIND" = "agent" ]; then
    mkdir -p "$proj/.claude/agents"
    if [ -d "$PATH_ARG" ]; then
      cp "$PATH_ARG"/*.md "$proj/.claude/agents/" 2>/dev/null || true
    else
      cp "$PATH_ARG" "$proj/.claude/agents/$(basename "$PATH_ARG")"
    fi
  else
    local name; name="$(basename "${PATH_ARG%/}")"
    mkdir -p "$proj/.claude/skills/$name"
    if [ -d "$PATH_ARG" ]; then
      cp "$PATH_ARG/SKILL.md" "$proj/.claude/skills/$name/SKILL.md" 2>/dev/null || true
    else
      cp "$PATH_ARG" "$proj/.claude/skills/$name/SKILL.md"
    fi
  fi
  echo "$proj"
}

# --- per-tool score helpers (each echoes a 0-100; dry-run -> fixed stub) ----

# skill-tools: native .score on a single skill path. skill-tools can exit
# nonzero (e.g. with --min-score) while still emitting valid JSON, so only
# fall back to a zero score when the captured output is unparseable.
sk_skill_tools() { [ -n "$DRY" ] && { echo 82; return; }
  skill-tools score -f json "$1" > "$tmpd/st.json" 2>/dev/null || true
  jq -e . "$tmpd/st.json" >/dev/null 2>&1 || echo '{"score":0}' > "$tmpd/st.json"
  adapt_skill_tools "$tmpd/st.json"; }

# skill-validator: check -o json -> top-level .errors / .warnings.
sk_validator() { [ -n "$DRY" ] && { echo 90; return; }
  skill-validator check "$1" -o json > "$tmpd/sv.json" 2>/dev/null || true
  local e w
  read -r e w < <(adapt_errwarn_json "$tmpd/sv.json" '.errors' '.warnings')
  normalize_errwarn "${e:-0}" "${w:-0}"; }

# claudelint: check-all --format json on a staged project, scoped to the
# relevant validator (Skills for skills, Agents for agents).
cl_score() { [ -n "$DRY" ] && { echo 70; return; }
  local proj vname
  proj="$(stage_project)"
  claudelint check-all --format json --cwd "$proj" > "$tmpd/cl.json" 2>/dev/null || true
  if [ "$KIND" = "agent" ]; then vname="Agents Validator"; else vname="Skills Validator"; fi
  local e w
  read -r e w < <(adapt_errwarn_json "$tmpd/cl.json" \
    "([.validators[]?|select(.name==\"$vname\")|.errors|length]|add)" \
    "([.validators[]?|select(.name==\"$vname\")|.warnings|length]|add)")
  normalize_errwarn "${e:-0}" "${w:-0}"; }

# agnix: --format json -> nested .summary.errors / .summary.warnings.
ag_agnix() { [ -n "$DRY" ] && { echo 80; return; }
  agnix --format json --target claude-code "$1" > "$tmpd/ax.json" 2>/dev/null || true
  local e w
  read -r e w < <(adapt_errwarn_json "$tmpd/ax.json" '.summary.errors' '.summary.warnings')
  normalize_errwarn "${e:-0}" "${w:-0}"; }

# cclint: --format json from inside a staged project -> totalErrors/Warnings.
ag_cclint() { [ -n "$DRY" ] && { echo 100; return; }
  local proj
  proj="$(stage_project)"
  ( cd "$proj" && cclint --format json ) > "$tmpd/cc.json" 2>/dev/null || true
  local e w
  read -r e w < <(adapt_errwarn_json "$tmpd/cc.json" '.totalErrors' '.totalWarnings')
  normalize_errwarn "${e:-0}" "${w:-0}"; }

# skillcheck: SARIF -> highest severity -> score + record severity for cap.
# NOTE: skillcheck exits nonzero when findings meet --fail-on (CRITICAL by
# default), so the exit code is NOT an error signal — it still writes valid
# SARIF. Only fall back to an empty run when the captured output is missing
# or not parseable JSON.
sec_score() { [ -n "$DRY" ] && { echo 100; echo none > "$tmpd/sev"; return; }
  skillcheck --format sarif "$1" > "$tmpd/sc.sarif" 2>/dev/null || true
  if ! jq -e . "$tmpd/sc.sarif" >/dev/null 2>&1; then
    echo '{"runs":[]}' > "$tmpd/sc.sarif"
  fi
  local sev; sev=$(adapt_sarif_severity "$tmpd/sc.sarif"); echo "$sev" > "$tmpd/sev"
  case "$sev" in
    CRITICAL) echo 50 ;;
    HIGH)     echo 80 ;;
    MEDIUM)   echo 90 ;;
    LOW)      echo 95 ;;
    *)        echo 100 ;;
  esac; }

# --- composition -----------------------------------------------------------

compute_quality() {
  local QS
  if [ "$KIND" = "agent" ]; then
    QS=$(ensemble3 50 "$(cl_score "$PATH_ARG")" 30 "$(ag_agnix "$PATH_ARG")" 20 "$(ag_cclint "$PATH_ARG")")
  else
    QS=$(ensemble3 40 "$(sk_skill_tools "$PATH_ARG")" 30 "$(sk_validator "$PATH_ARG")" 30 "$(cl_score "$PATH_ARG")")
  fi
  echo "$QS"
}

emit_review() {
  local q; q="$(compute_quality)"
  jq -nc --arg kind "$KIND" --arg name "$(basename "$PATH_ARG")" \
    --argjson q "$q" '{identity:{kind:$kind,name:$name},quality:{score:$q}}'
}

# --- gate (deterministic structural veto) ----------------------------------

# quick_validate: prefer the vendored skill-creator quick_validate.py (needs
# PyYAML). $SKILLS_REVIEW_QUICK_VALIDATE may pin its path; the env may put it
# on PATH. If neither runs, fall back to a minimal inline frontmatter check
# (frontmatter parses + has name + description) so the gate stays offline and
# dependency-free.
quick_validate() {
  local skill_dir="$1" qv="${SKILLS_REVIEW_QUICK_VALIDATE:-}"
  if [ -z "$qv" ] && command -v quick_validate.py >/dev/null 2>&1; then
    qv="$(command -v quick_validate.py)"
  fi
  if [ -n "$qv" ] && [ -f "$qv" ] && python3 -c 'import yaml' >/dev/null 2>&1; then
    python3 "$qv" "$skill_dir" >/dev/null 2>&1
    return $?
  fi
  inline_frontmatter_ok "$skill_dir"
}

# Minimal SKILL.md frontmatter gate: SKILL.md exists, opens with `---`,
# closes with `---`, and the block carries `name:` and `description:`.
inline_frontmatter_ok() {
  local md="$1/SKILL.md"
  [ -f "$md" ] || return 1
  awk '
    NR==1 && /^---[[:space:]]*$/ { inb=1; next }
    inb && /^---[[:space:]]*$/   { closed=1; exit }
    inb && /^[[:space:]]*name:/        { have_name=1 }
    inb && /^[[:space:]]*description:/ { have_desc=1 }
    END { exit (closed && have_name && have_desc) ? 0 : 1 }
  ' "$md"
}

# Optional behavioral stage (promptfoo). Key-gated; feeds impact only.
run_behavioral() { promptfoo eval -c "$1" >/dev/null 2>&1 && echo 80 || echo 70; }

# Emit `{ "score": <ensemble>, "checks": [per-member breakdown] }` for the
# per-kind quality ensemble. Echoing both keeps the tool invocations to one
# pass even though this runs in a subshell.
quality_block() {
  local a b c wa wb wc na nb nc
  if [ "$KIND" = "agent" ]; then
    wa=50; na=claudelint;      a="$(cl_score "$PATH_ARG")"
    wb=30; nb=agnix;           b="$(ag_agnix "$PATH_ARG")"
    wc=20; nc=cclint;          c="$(ag_cclint "$PATH_ARG")"
  else
    wa=40; na=skill-tools;     a="$(sk_skill_tools "$PATH_ARG")"
    wb=30; nb=skill-validator; b="$(sk_validator "$PATH_ARG")"
    wc=30; nc=claudelint;      c="$(cl_score "$PATH_ARG")"
  fi
  local q; q=$(ensemble3 "$wa" "$a" "$wb" "$b" "$wc" "$c")
  jq -nc --argjson q "$q" \
    --arg na "$na" --argjson wa "$wa" --argjson sa "$a" \
    --arg nb "$nb" --argjson wb "$wb" --argjson sb "$b" \
    --arg nc "$nc" --argjson wc "$wc" --argjson sc "$c" '
    { score:$q, checks:
      [ {id:$na, weight:$wa, note:($sa|tostring), pass:($sa>=60)},
        {id:$nb, weight:$wb, note:($sb|tostring), pass:($sb>=60)},
        {id:$nc, weight:$wc, note:($sc|tostring), pass:($sc>=60)} ] }'
}

emit_audit() {
  local q r s i sev overall status quality est
  quality="$(quality_block)"; q="$(echo "$quality" | jq -r '.score')"
  run_gate >/dev/null
  # reliability = gate pass/fail, floored by claudelint conformance.
  if [ "${GATE_OK:-0}" = "1" ]; then
    r="$(cl_score "$PATH_ARG")"; [ "$r" -lt 60 ] && r=60
  else
    r=0
  fi
  s="$(sec_score "$PATH_ARG")"; sev="$(cat "$tmpd/sev" 2>/dev/null || echo none)"
  if [ -n "$WITH_BEHAVIORAL" ] && [ -z "$DRY" ]; then
    i="$(run_behavioral "$PATH_ARG")"; est=false
  else
    i=70; est=true
  fi
  overall="$(fuse "$q" "$r" "$s" "$i")"
  overall="$(apply_cap "$overall" "$sev")"
  status="$(pill "$overall")"
  jq -nc --arg kind "$KIND" --arg name "$(basename "$PATH_ARG")" \
    --arg dir "$PATH_ARG" \
    --argjson overall "$overall" --arg status "$status" \
    --argjson quality "$quality" \
    --argjson r "$r" --argjson s "$s" --argjson i "$i" \
    --argjson est "$est" \
    --argjson cap "$(apply_cap 100 "$sev")" --arg sev "$sev" '
    { identity:{kind:$kind, name:$name, dir:$dir},
      overall:$overall, status:$status,
      quality:$quality,
      reliability:{score:$r},
      security:{score:$s, cap:$cap, severity:$sev},
      impact:{score:$i, estimated:$est} }'
}

run_gate() { # echoes 100 (pass) or 0 (fail); sets $GATE_OK
  if [ -n "${SKILLS_REVIEW_FORCE_GATE_FAIL:-}" ]; then GATE_OK=0; echo 0; return; fi
  if [ -n "$DRY" ]; then GATE_OK=1; echo 100; return; fi
  if [ "$KIND" = "agent" ]; then
    # Agent gate: claudelint must parse the agent schema cleanly (0 errors).
    local proj e
    proj="$(stage_project)"
    claudelint check-all --format json --cwd "$proj" > "$tmpd/gate.json" 2>/dev/null || true
    e=$(jq -r '([.validators[]?|select(.name=="Agents Validator")|.errors|length]|add) // 0' \
          "$tmpd/gate.json" 2>/dev/null || echo 0)
    if [ "${e:-0}" -eq 0 ]; then GATE_OK=1; echo 100; else GATE_OK=0; echo 0; fi
  else
    if quick_validate "$PATH_ARG"; then GATE_OK=1; echo 100; else GATE_OK=0; echo 0; fi
  fi
}

# Apply --threshold against an .overall-or-.quality.score in a result JSON.
threshold_gate() { # <result-json>
  [ -n "$THRESHOLD" ] || return 0
  local v
  v="$(echo "$1" | jq -r '.overall // .quality.score')"
  [ "$v" -ge "$THRESHOLD" ] || exit 1
}

case "$CMD" in
  review)
    res="$(emit_review)"
    if [ -n "$JSON" ]; then echo "$res"
    else echo "$res" | jq -r '"\(.identity.kind) \(.identity.name): quality \(.quality.score)"'; fi
    threshold_gate "$res" ;;
  lint)
    run_gate >/dev/null
    if [ "${GATE_OK:-0}" = "1" ]; then echo "lint: OK ($KIND)"; exit 0
    else echo "lint: FAILED gate ($KIND)" >&2; exit 1; fi ;;
  audit)
    res="$(emit_audit)"
    if [ -n "$JSON" ]; then echo "$res"
    else echo "$res" | jq -r '"\(.identity.kind) \(.identity.name): \(.overall) (\(.status))"'; fi
    threshold_gate "$res" ;;
  *) echo "unknown command: $CMD" >&2; exit 2 ;;
esac
